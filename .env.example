# =====================================================================
# Proveedor LLM
# Elegí UNO de los tres bloques de abajo y dejá los otros comentados.
# =====================================================================

# --- Opción A: Ollama (local, default recomendado para dev) -----------
# No requiere api key. Asegurate de tener el daemon corriendo
# (`ollama serve`) y el modelo descargado (`ollama pull llama3.2:3b`).
LLM_PROVIDER=ollama
LLM_MODEL_NAME=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
# LLM_API_KEY no aplica para ollama, dejar vacío o sin definir.

# --- Opción B: OpenAI -------------------------------------------------
# LLM_PROVIDER=openai
# LLM_MODEL_NAME=gpt-4o-mini
# LLM_API_KEY=sk-...

# --- Opción C: Anthropic ----------------------------------------------
# LLM_PROVIDER=anthropic
# LLM_MODEL_NAME=claude-haiku-4-5-20251001
# LLM_API_KEY=sk-ant-...

# =====================================================================
# Parámetros de inferencia
# =====================================================================
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30

# =====================================================================
# Memoria conversacional
# =====================================================================
MAX_SESSION_HISTORY=20

# =====================================================================
# Entorno (development | staging | production)
# =====================================================================
APP_ENVIRONMENT=development
